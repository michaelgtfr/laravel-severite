{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "michaelgtfr/laravel-severite",
    "type": "library",
    "description": "Integration of XHProf for Laravel",
    "license": "MIT",
    "authors": [
        {
            "name": "Garret Michael"
        }
    ],
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0"
    },
    "require-dev": {
        "inertiajs/inertia-laravel": "^2.0",
        "orchestra/testbench": "^10.11",
        "pestphp/pest": "^4.6",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "Severite\\": "src/",
            "SeveriteScript\\": "script/",
            "Severite\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Severite\\": "src/",
            "Severite\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Severite\\Providers\\SeveriteServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable"
}
